{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "DetailedErrors": true,
  "SqlConnectionStringBuilder": {
    "DataSource": "(localdb)\\MSSQLLocalDB",
    "IntegratedSecurity": true
  },
  "MongoServerHost": "localhost",
  "MongoServerPort": 27017,
  "MongoUseTls": false,
  "RedisHost": "localhost",
  "RedisPort": 6379,
  "RedisSsl": false,
  "OidcAuthority": "https://localhost:7261",
  "InventoryServerAddress": "https://localhost:7150",
  "ManualsApiAddress": "https://localhost:7099",
  "ProductsApiAddress": "https://localhost:7057",
  "ServiceBusConnectionString": null
}
